# Multi-Database MCP Server Configuration
# Database type is auto-detected from the connection URL
# For read-only access, connections are automatically configured as read-only

# ============================================
# PostgreSQL Examples
# ============================================
# Requires: pip install db-mcp[postgresql]
# Driver: asyncpg (async PostgreSQL driver)

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mydb

# Remote PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:pass@remote-host.com:5432/production_db

# With SSL
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db?ssl=require

# ============================================
# MySQL Examples
# ============================================
# Requires: pip install db-mcp[mysql]
# Driver: aiomysql (async MySQL driver)

# DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/mydb

# ============================================
# ClickHouse Examples
# ============================================
# Requires: pip install db-mcp[clickhouse]
# Driver: clickhouse-connect (async ClickHouse driver)

# DATABASE_URL=clickhouse+connect://default:password@localhost:9000/default
# or
# DATABASE_URL=clickhouse://default:password@localhost:9000/default

# ============================================
# SSH Tunnel Configuration (Optional)
# ============================================
# Enable SSH tunneling to connect to databases behind firewalls or bastion hosts.
# When SSH_HOST is set, the server will establish an SSH tunnel before connecting.
# The DATABASE_URL should still point to the remote database - it will be
# automatically rewritten to connect through the tunnel.

# SSH Server (required to enable tunneling)
# SSH_HOST=bastion.example.com
# SSH_PORT=22
# SSH_USERNAME=dbuser

# Authentication Method 1: Password
# SSH_PASSWORD=secretpassword

# Authentication Method 2: Private Key (preferred)
# SSH_PRIVATE_KEY_PATH=/path/to/id_rsa
# SSH_PRIVATE_KEY_PASSPHRASE=keypassphrase  # Optional, for encrypted keys

# Remote Database (as seen from SSH server)
# Default: 127.0.0.1 (database on same host as SSH server)
# SSH_REMOTE_HOST=db.internal.example.com
# SSH_REMOTE_PORT=5432

# Local Tunnel Binding (optional)
# SSH_LOCAL_HOST=127.0.0.1
# SSH_LOCAL_PORT=  # Leave empty for auto-assignment

# Tunnel Timeout (optional)
# SSH_TUNNEL_TIMEOUT=10

# ============================================
# Optional Connection Pool Settings
# ============================================
# These can also be passed via connection URL parameters

# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_STATEMENT_TIMEOUT=30

# ============================================
# Testing Database URLs
# ============================================
# Separate environment variables for testing purposes
# These are used by the test scripts in tests/ directory

# PostgreSQL test database
# PG_TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/test_db

# ClickHouse test database
# CH_TEST_DATABASE_URL=clickhouse+connect://default:password@localhost:9000/test_db
# or
# CH_TEST_DATABASE_URL=clickhouse://default:password@localhost:9000/test_db

# ============================================
# Local Development Database (Docker Compose)
# ============================================
# Use this for local testing with the Docker Compose setup in tests/docker/
# Start the database with: cd tests/docker && docker-compose up -d
#
# This database includes comprehensive sample data for testing all MCP server features.
# See tests/docker/README.md for setup instructions.

# Local PostgreSQL 17 (default credentials from docker-compose.yml)
# DATABASE_URL=postgresql+asyncpg://devuser:devpassword@localhost:5432/devdb

# Alternative: use for testing specifically
# PG_TEST_DATABASE_URL=postgresql+asyncpg://devuser:devpassword@localhost:5432/devdb
